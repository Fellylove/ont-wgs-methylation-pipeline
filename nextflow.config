/*
========================================================================================
   ONT WGS Methylation Pipeline - Configuration
========================================================================================
   Scalable configuration supporting:
   - Local execution
   - HPC (SLURM)
   - Cloud (AWS Batch)
   - Multiple reference genomes (GRCh38, T2T-CHM13)
========================================================================================
*/

// ========== PARAMETERS ==========
params {
    // Input/Output
    input = null
    outdir = 'results'
    
    // Reference genome selection
    genome = null
    
    // Reference genome paths (configured per genome)
    genomes {
        'GRCh38' {
            fasta = '/references/GRCh38/GRCh38.primary_assembly.genome.fa'
            fai = '/references/GRCh38/GRCh38.primary_assembly.genome.fa.fai'
        }
        'T2T-CHM13' {
            fasta = '/references/T2T-CHM13/chm13v2.0.fa'
            fai = '/references/T2T-CHM13/chm13v2.0.fa.fai'
        }
    }
    
    // Workflow options
    skip_basecalling = false
    skip_methylation = false
    skip_sv = false
    
    // Filtering parameters
    min_read_length = 1000
    min_read_quality = 10
    
    // Resource limits
    max_cpus = 64
    max_memory = '256.GB'
    max_time = '48.h'
    
    // Reporting
    email = null
    generate_dag = false
}

// ========== CONTAINER CONFIGURATION ==========
singularity {
    enabled = true
    autoMounts = true
    cacheDir = './singularity_cache'
    runOptions = '--nv'  // Enable GPU support for Dorado
}

docker {
    enabled = false
    temp = 'auto'
}

// ========== PROCESS CONFIGURATION ==========
process {
    // Default resources
    cpus = 1
    memory = '4.GB'
    time = '2.h'
    
    // Error handling - retry on common exit codes
    errorStrategy = { task.exitStatus in [143,137,104,134,139,247] ? 'retry' : 'finish' }
    maxRetries = 3
    
    // Resource scaling on retry
    cpus = { check_max( 2 * task.attempt, 'cpus' ) }
    memory = { check_max( 4.GB * task.attempt, 'memory' ) }
    time = { check_max( 4.h * task.attempt, 'time' ) }
    
    // ========== PROCESS-SPECIFIC RESOURCES ==========
    
    // Basecalling (GPU-accelerated)
    withName: 'DORADO_BASECALL' {
        container = 'ontresearch/dorado:latest'
        cpus = { check_max( 8, 'cpus' ) }
        memory = { check_max( 32.GB, 'memory' ) }
        time = { check_max( 24.h, 'time' ) }
        accelerator = 1  // Request 1 GPU
        clusterOptions = { task.executor == 'slurm' ? '--gres=gpu:1' : '' }
    }
    
    // QC processes (low resources)
    withName: 'PYCOQC|NANOPLOT.*|MULTIQC' {
        cpus = { check_max( 2, 'cpus' ) }
        memory = { check_max( 8.GB, 'memory' ) }
        time = { check_max( 2.h, 'time' ) }
    }
    
    // Coverage analysis
    withName: 'MOSDEPTH' {
        container = 'quay.io/biocontainers/mosdepth:0.3.3--hd299d5a_3'
        cpus = { check_max( 4, 'cpus' ) }
        memory = { check_max( 16.GB, 'memory' ) }
        time = { check_max( 4.h, 'time' ) }
    }
    
    // Filtering (low resources)
    withName: 'NANOFILT' {
        container = 'quay.io/biocontainers/nanofilt:2.8.0--py_0'
        cpus = { check_max( 2, 'cpus' ) }
        memory = { check_max( 8.GB, 'memory' ) }
        time = { check_max( 4.h, 'time' ) }
    }
    
    // Alignment (high resources)
    withName: 'MINIMAP2.*' {
        container = 'quay.io/biocontainers/minimap2:2.24--h7132678_1'
        cpus = { check_max( 16, 'cpus' ) }
        memory = { check_max( 64.GB, 'memory' ) }
        time = { check_max( 12.h, 'time' ) }
    }
    
    // Structural variant calling
    withName: 'SNIFFLES2' {
        container = 'quay.io/biocontainers/sniffles:2.0.7--pyhdfd78af_0'
        cpus = { check_max( 8, 'cpus' ) }
        memory = { check_max( 32.GB, 'memory' ) }
        time = { check_max( 8.h, 'time' ) }
    }
    
    // Small variant calling (very high resources)
    withName: 'CLAIR3' {
        container = 'hkubal/clair3:latest'
        cpus = { check_max( 32, 'cpus' ) }
        memory = { check_max( 128.GB, 'memory' ) }
        time = { check_max( 24.h, 'time' ) }
    }
    
    // Methylation calling
    withName: 'MODKIT.*' {
        container = 'ontresearch/modkit:latest'
        cpus = { check_max( 16, 'cpus' ) }
        memory = { check_max( 64.GB, 'memory' ) }
        time = { check_max( 12.h, 'time' ) }
    }
    
    // Phasing
    withName: 'WHATSHAP.*' {
        container = 'quay.io/biocontainers/whatshap:1.7--py310h4b81fae_0'
        cpus = { check_max( 8, 'cpus' ) }
        memory = { check_max( 32.GB, 'memory' ) }
        time = { check_max( 8.h, 'time' ) }
    }
}

// ========== EXECUTION PROFILES ==========
profiles {
    // Local execution (laptop/workstation)
    standard {
        process.executor = 'local'
        process.cpus = 4
        process.memory = '16.GB'
    }
    
    // HPC with SLURM scheduler
    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'
        
        // CUSTOMIZE THIS for your HPC
        process.clusterOptions = '--account=genomics --qos=normal'
        
        // Executor settings
        executor {
            queueSize = 50
            submitRateLimit = '10/1min'
            pollInterval = '30sec'
        }
        
        // Resource limits for HPC
        params.max_cpus = 64
        params.max_memory = '256.GB'
        params.max_time = '48.h'
    }
    
    // AWS Batch (cloud execution)
    aws {
        process.executor = 'awsbatch'
        process.queue = 'ont-wgs-queue'
        
        aws {
            region = 'us-west-2'
            batch {
                cliPath = '/home/ec2-user/miniconda/bin/aws'
                maxTransferAttempts = 3
                delayBetweenAttempts = '30 sec'
            }
        }
        
        // GPU instance for basecalling
        withName: 'DORADO_BASECALL' {
            machineType = 'g4dn.xlarge'
        }
        
        // High-memory instance for alignment
        withName: 'MINIMAP2_ALIGN' {
            machineType = 'r5.4xlarge'
        }
        
        // High-CPU instance for variant calling
        withName: 'CLAIR3' {
            machineType = 'c5.9xlarge'
        }
    }
    
    // Test profile (quick test with small resources)
    test {
        process.executor = 'local'
        process.cpus = 2
        process.memory = '8.GB'
        process.time = '1.h'
        
        params.input = 'test_data/samplesheet.csv'
        params.genome = 'GRCh38'
        params.outdir = 'test_results'
    }
}

// ========== RESOURCE LIMIT CHECKING ==========
def check_max(obj, type) {
    if (type == 'cpus') {
        return Math.min(obj as int, params.max_cpus as int)
    } else if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "ERROR: invalid max memory '${params.max_memory}'"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "ERROR: invalid max time '${params.max_time}'"
            return obj
        }
    }
}

// ========== EXECUTION MONITORING ==========

// Execution report
report {
    enabled = true
    overwrite = true
    file = "${params.outdir}/reports/execution_report.html"
}

// Timeline visualization
timeline {
    enabled = true
    overwrite = true
    file = "${params.outdir}/reports/timeline.html"
}

// Detailed trace
trace {
    enabled = true
    overwrite = true
    file = "${params.outdir}/reports/trace.txt"
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,vol_ctxt,inv_ctxt'
}

// DAG visualization
dag {
    enabled = params.generate_dag
    overwrite = true
    file = "${params.outdir}/reports/pipeline_dag.svg"
}

// ========== MANIFEST ==========
manifest {
    name = 'ONT WGS Methylation Pipeline'
    author = 'Sylvia Burris'
    homePage = 'https://github.com/Fellylove/ont-wgs-methylation-pipeline'
    description = 'Production-grade Oxford Nanopore WGS pipeline with integrated methylation calling'
    mainScript = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version = '1.0.0'
}

// ========== TOWER INTEGRATION (Optional) ==========
/*
tower {
    enabled = false
    accessToken = env.TOWER_ACCESS_TOKEN
}
*/
